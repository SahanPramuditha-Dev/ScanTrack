rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function adminByClaim() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function adminByProfile() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/employees/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.role == 'admin';
    }

    function isAdmin() {
      return adminByClaim() || adminByProfile();
    }

    match /employees/{userId} {
      allow read: if isSignedIn() &&
        (
          request.auth.uid == userId ||
          isAdmin() ||
          resource.data.email == request.auth.token.email
        );

      allow create: if isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.data.keys().hasOnly(['name', 'email', 'role', 'active', 'createdAt', 'updatedAt']) &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.role == 'employee';

      allow update: if isSignedIn() && request.auth.uid == userId &&
        request.resource.data.keys().hasOnly(['name', 'email', 'role', 'active', 'createdAt', 'updatedAt']) &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.role == resource.data.role;

      allow write: if isAdmin();
    }

    match /attendance_daily/{docId} {
      allow read: if isSignedIn() && (isAdmin() || request.auth.uid == resource.data.userId);

      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        docId.matches(request.auth.uid + '_.*');

      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.date == resource.data.date;

      allow delete: if isAdmin();
    }

    match /attendance_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /qr_tokens/{tokenId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
