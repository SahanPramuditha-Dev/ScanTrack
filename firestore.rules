rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminClaim() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isAdminProfile() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/employees/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.role == 'admin';
    }

    function isAdmin() {
      return isAdminClaim() || isAdminProfile();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validTokenScanUpdate() {
      let prevScans = (resource.data.scansCount is int) ? resource.data.scansCount : 0;
      return isSignedIn() &&
        resource.data.active is bool &&
        resource.data.active == true &&
        request.resource.data.active == false &&
        request.resource.data.lastUsedBy == request.auth.uid &&
        request.resource.data.scansCount == (prevScans + 1) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'active',
          'lastUsedAt',
          'lastUsedBy',
          'scansCount',
          'updatedAt'
        ]);
    }

    match /employees/{userId} {
      allow read: if isOwner(userId) ||
        isAdmin() ||
        (isSignedIn() && resource.data.email == request.auth.token.email);

      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasOnly(['name', 'email', 'role', 'active', 'createdAt', 'updatedAt']) &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.role == 'employee';

      allow update: if isOwner(userId) &&
        request.resource.data.keys().hasOnly(['name', 'email', 'role', 'active', 'createdAt', 'updatedAt']) &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.role == resource.data.role;
    }

    match /attendance_daily/{docId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);

      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        docId.matches(request.auth.uid + '_.*');

      allow update: if isAdmin() ||
        (isSignedIn() &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.date == resource.data.date);

      allow delete: if isAdmin();
    }

    match /attendance_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /qr_tokens/{tokenId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || validTokenScanUpdate();
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /salary_records/{docId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /daily_payments/{docId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
